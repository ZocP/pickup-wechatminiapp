.capacity-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.capacity-label {
  font-size: 24rpx;
  color: #646566;
  min-width: 80rpx;
  flex-shrink: 0;
}

.bar-wrapper {
  flex: 1;
  min-width: 0;
}

.bar-bg {
  height: 16rpx;
  background: #f2f3f5;
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.capacity-text {
  font-size: 24rpx;
  color: #323233;
  min-width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

.full-badge {
  font-size: 20rpx;
  color: #fff;
  background: #ee0a24;
  border-radius: 4rpx;
  padding: 2rpx 8rpx;
  flex-shrink: 0;
}
