<view class="shift-card">
  <view class="header">
    <view class="header-left">
      <text class="departure">{{headerTime}}</text>
      <text class="flights">{{flightsText}}</text>
    </view>
    <view class="header-right">
      <van-tag type="{{statusType}}" plain>{{statusText}}</van-tag>
      <van-tag wx:if="{{hasDelayWarning}}" type="danger" custom-class="warn-tag">{{i18n.shiftcard_delay_warning}}</van-tag>
    </view>
  </view>

  <view class="body">
    <view class="row driver-row">
      <text class="label">{{i18n.shiftcard_driver_label}}</text>
      <text class="value">{{driverText}}</text>
    </view>

    <!-- 车辆建议 -->
    <view class="vehicle-info" wx:if="{{vehicleText}}">
      <text class="vehicle-label">🚗 {{vehicleText}}</text>
    </view>

    <!-- 登车状态 -->
    <view class="boarding-status" wx:if="{{boardedCount !== undefined && unboardedCount !== undefined}}">
      <view class="boarding-row">
        <text class="boarding-label">{{i18n.shiftcard_boarded}}</text>
        <text class="boarding-value boarded">{{boardedCount}}{{i18n.shiftcard_boarded_unit}}</text>
      </view>
      <view class="boarding-row">
        <text class="boarding-label">{{i18n.shiftcard_waiting}}</text>
        <text class="boarding-value unboarded">{{unboardedCount}}{{i18n.shiftcard_waiting_unit}}</text>
      </view>
    </view>

    <van-notice-bar
      wx:if="{{showRouteNotice}}"
      left-icon="volume-o"
      text="{{i18n.shiftcard_route_prefix}}{{routeText}}"
      color="#ee0a24"
      background="#fff1f0"
    />

    <view class="staffs" wx:if="{{staffs.length}}">
      <text class="section-title">{{i18n.shiftcard_staff_title}}</text>
      <view class="staff-tags">
        <van-tag
          wx:for="{{staffs}}"
          wx:key="id"
          type="primary"
          plain
          custom-class="staff-tag"
        >
          <van-icon name="star" size="12px" />
          <text class="staff-text"> {{item.role || i18n.shiftcard_volunteer}}-{{item.name || (i18n.shiftcard_member_prefix + item.id)}}</text>
        </van-tag>
      </view>
    </view>

    <view class="resource">
      <view class="resource-row">
        <text class="resource-title">{{seatUsage.label}}</text>
        <text class="resource-value overload-{{seatUsage.isOverload}}">{{seatUsage.used}} / {{seatUsage.max}} {{seatUsage.overloadText}}</text>
      </view>
      <van-progress
        percentage="{{seatUsage.percent}}"
        stroke-width="8"
        color="{{seatUsage.color}}"
        pivot-text=""
        show-pivot="false"
      />

      <view class="resource-row top-gap">
        <text class="resource-title">{{checkedUsage.label}}</text>
        <text class="resource-value overload-{{checkedUsage.isOverload}}">{{checkedUsage.used}} / {{checkedUsage.max}} {{checkedUsage.overloadText}}</text>
      </view>
      <van-progress
        percentage="{{checkedUsage.percent}}"
        stroke-width="8"
        color="{{checkedUsage.color}}"
        pivot-text=""
        show-pivot="false"
      />

      <view class="resource-row top-gap">
        <text class="resource-title">{{carryOnUsage.label}}</text>
        <text class="resource-value overload-{{carryOnUsage.isOverload}}">{{carryOnUsage.used}} / {{carryOnUsage.max}} {{carryOnUsage.overloadText}}</text>
      </view>
      <van-progress
        percentage="{{carryOnUsage.percent}}"
        stroke-width="8"
        color="{{carryOnUsage.color}}"
        pivot-text=""
        show-pivot="false"
      />
    </view>
  </view>

  <view class="footer">
    <van-button
      size="small"
      type="primary"
      plain
      bind:tap="onTapManageShift"
    >{{i18n.shiftcard_manage_btn}}</van-button>
  </view>
</view>
