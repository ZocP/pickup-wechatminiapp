.vehicle-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.color-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
}

.driver-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.label {
  font-size: 24rpx;
  color: #969799;
}

.value {
  font-size: 24rpx;
  color: #323233;
}

.value.muted {
  color: #c8c9cc;
}

.boarding-status {
  display: flex;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.boarding-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.boarding-label {
  font-size: 24rpx;
  color: #646566;
}

.boarding-value {
  font-size: 28rpx;
  font-weight: 600;
}

.boarding-value.boarded {
  color: #07c160;
}

.boarding-value.pending {
  color: #ff976a;
}

.capacity-section {
  margin-bottom: 16rpx;
}

.passenger-section {
  border-top: 1rpx solid #f2f3f5;
  padding-top: 16rpx;
}

.passenger-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.passenger-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.passenger-name {
  font-size: 28rpx;
  color: #323233;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.passenger-detail {
  font-size: 22rpx;
  color: #969799;
}

.remove-btn {
  color: #ee0a24;
  padding: 8rpx;
  flex-shrink: 0;
}

.add-section {
  margin-top: 16rpx;
  display: flex;
  justify-content: center;
}

.add-btn {
  width: auto !important;
}
