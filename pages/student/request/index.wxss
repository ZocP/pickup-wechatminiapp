.request-page {
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.stepper-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 32rpx;
}

.stepper-label {
  font-size: 28rpx;
  color: #323233;
}

.tracker-card {
  margin-top: 20rpx;
}

.submit-locked {
  font-size: 26rpx;
  color: #646566;
}

.latest {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #323233;
}

.card-inner {
  margin-top: 16rpx;
  border: 1rpx solid #ebedf0;
  border-radius: 12rpx;
  padding: 18rpx;
}

.inner-title {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.line {
  font-size: 24rpx;
  color: #646566;
  margin-top: 6rpx;
}
