<view class="page request-page">
  <view class="card" wx:if="{{!hasSubmitted}}">
    <view class="section-title">提交接机申请</view>
    <van-cell-group inset>
      <van-field
        label="真实姓名"
        placeholder="请输入你的真实姓名"
        value="{{form.real_name}}"
        data-field="real_name"
        bind:change="onFieldChange"
      />
      <van-field
        label="航班号"
        placeholder="如 UA851"
        value="{{form.flight_no}}"
        data-field="flight_no"
        bind:change="onFieldChange"
      />
      <view bindtap="openDatePicker">
        <van-field
          label="落地日期"
          placeholder="请选择日期"
          value="{{form.arrival_date}}"
          readonly
          is-link
        />
      </view>
      <van-field
        label="航站楼"
        placeholder="请选择航站楼"
        value="{{form.terminal}}"
        readonly
        is-link
        bind:click-input="openTerminalPicker"
      />
      <van-field
        label="预计落地时间"
        placeholder="请选择时间"
        value="{{form.arrival_time}}"
        readonly
        is-link
        bind:click-input="openTimePicker"
      />
      <view class="stepper-row">
        <text class="stepper-label">托运箱数量</text>
        <van-stepper value="{{form.checked_bags}}" min="0" bind:change="onStepperCheckedChange" />
      </view>
      <view class="stepper-row">
        <text class="stepper-label">登机箱数量</text>
        <van-stepper value="{{form.carry_on_bags}}" min="0" bind:change="onStepperCarryOnChange" />
      </view>
      <van-field
        label="同乘备注"
        type="textarea"
        autosize
        maxlength="200"
        placeholder="可选：想和谁同一班车（如：想和张三同车）"
        value="{{form.ride_with_note}}"
        data-field="ride_with_note"
        bind:change="onFieldChange"
      />
      <van-field
        label="对方微信号"
        maxlength="20"
        placeholder="可选：仅字母数字下划线，6-20位"
        value="{{form.ride_with_wechat}}"
        data-field="ride_with_wechat"
        bind:change="onFieldChange"
      />
    </van-cell-group>

    <van-button
      type="primary"
      block
      loading="{{submitting}}"
      custom-style="margin-top: 24rpx;"
      bind:tap="onSubmit"
    >提交申请</van-button>
  </view>

  <view class="card" wx:else>
    <view class="section-title">提交接机申请</view>
    <view class="submit-locked">你已提交过申请，当前仅可查看申请状态追踪。</view>
  </view>

  <view class="card tracker-card">
    <view class="section-title">申请状态追踪</view>

    <view wx:if="{{loadingTrack}}">
      <van-skeleton title row="3" />
    </view>

    <view wx:elif="{{!latestRequest}}">
      <van-empty description="暂无申请记录" />
    </view>

    <view wx:else>
      <van-steps steps="{{trackSteps}}" active="{{activeStep}}" direction="horizontal" />

      <view class="latest">
        <text>当前航班：{{latestRequest.flight_no}}</text>
        <van-tag type="primary" plain custom-style="margin-left: 12rpx;">{{latestRequest.status_text || latestRequest.status}}</van-tag>
      </view>
      <view wx:if="{{latestRequest.ride_with_note}}" class="line">同乘备注：{{latestRequest.ride_with_note}}</view>
      <view wx:if="{{latestRequest.ride_with_wechat}}" class="line">对方微信号：{{latestRequest.ride_with_wechat}}</view>

      <view wx:if="{{assignedShift}}" class="assigned card-inner">
        <view class="inner-title">已分配车辆信息</view>
        <view class="line">司机：{{assignedShift.driver.name || '--'}}</view>
        <view class="line">车型：{{assignedShift.driver.car_model || '--'}}</view>
        <view class="line">集合点：Terminal {{latestRequest.terminal || '--'}}</view>
        <view class="line">出发时间：{{assignedShift.departure_time || '--'}}</view>
        
        <!-- 登车二维码 -->
        <view class="qr-code-section">
          <view class="inner-title">登车二维码</view>
          <view class="qr-code-tips">请向司机出示此二维码进行登车核销</view>
          
          <view wx:if="{{generatingQrCode}}" class="qr-code-loading">
            <van-loading size="24px">生成二维码中...</van-loading>
          </view>
          
          <view wx:elif="{{qrCodePath}}" class="qr-code-container">
            <image src="{{qrCodePath}}" class="qr-code-image" mode="widthFix" />
            <view class="qr-code-actions">
              <van-button 
                type="primary" 
                size="small" 
                bindtap="openQrCodeModal"
              >
                查看大图
              </van-button>
              <van-button 
                type="default" 
                size="small" 
                bindtap="saveQrCodeToAlbum"
              >
                保存到相册
              </van-button>
            </view>
          </view>
          
          <view wx:else class="qr-code-empty">
            <van-empty description="{{qrCodeError || '二维码生成失败'}}" mode="list" />
            <view wx:if="{{qrCodeError}}" class="qr-code-error">{{qrCodeError}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 隐藏的canvas用于生成二维码 -->
  <block wx:if="{{showQrCanvas}}">
    <canvas 
      id="qrCodeCanvas" 
      style="position: absolute; left: -9999rpx; width: 200px; height: 200px;" 
      type="2d"
    />
    <canvas
      id="qrCodeCanvasLegacy"
      canvas-id="qrCodeCanvasLegacy"
      style="position: absolute; left: -9999rpx; width: 200px; height: 200px;"
    />
  </block>

  <van-action-sheet
    show="{{showTerminalPicker}}"
    title="选择航站楼"
    actions="{{terminalActions}}"
    close-on-click-action="true"
    bind:select="onSelectTerminal"
    bind:close="onCloseTerminalPicker"
  />

  <van-calendar
    show="{{showDatePicker}}" min-date="{{calendarMinDate}}" max-date="{{calendarMaxDate}}"
    type="single"
    bind:close="onDatePickerClose"
    bind:confirm="onDateConfirm"
  />

  <van-popup show="{{showTimePicker}}" position="bottom" bind:close="onTimePickerCancel">
    <van-datetime-picker
      type="time"
      value="{{timePickerValue}}"
      title="选择时间"
      bind:cancel="onTimePickerCancel"
      bind:confirm="onTimeConfirm"
    />
  </van-popup>

  <!-- 二维码大图模态框 -->
  <van-popup 
    show="{{showQrCodeModal}}" 
    position="center" 
    round
    bind:close="closeQrCodeModal"
  >
    <view class="qr-code-modal">
      <view class="modal-header">
        <text class="modal-title">登车二维码</text>
        <van-icon name="cross" size="18px" bindtap="closeQrCodeModal" />
      </view>
      
      <view class="modal-content">
        <view wx:if="{{qrCodePath}}" class="large-qr-code">
          <image src="{{qrCodePath}}" class="qr-code-large-image" mode="widthFix" />
          <view class="qr-code-instruction">
            请向司机出示此二维码进行登车核销
          </view>
        </view>
        
        <view class="modal-actions">
          <van-button 
            type="primary" 
            block
            bindtap="saveQrCodeToAlbum"
          >
            保存到相册
          </van-button>
        </view>
      </view>
    </view>
  </van-popup>
</view>