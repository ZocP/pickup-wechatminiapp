<view class="page request-page">
  <view class="card" wx:if="{{!hasSubmitted}}">
    <view class="section-title">{{i18n.student_request_title}}</view>
    <van-cell-group inset>
      <van-field
        label="{{i18n.student_request_name_label}}"
        placeholder="{{i18n.student_request_name_placeholder}}"
        value="{{form.real_name}}"
        data-field="real_name"
        bind:change="onFieldChange"
      />
      <van-field
        label="{{i18n.student_request_flight_label}}"
        placeholder="{{i18n.student_request_flight_placeholder}}"
        value="{{form.flight_no}}"
        data-field="flight_no"
        bind:change="onFieldChange"
      />
      <view bindtap="openDatePicker">
        <van-field
          label="{{i18n.student_request_date_label}}"
          placeholder="{{i18n.student_request_date_placeholder}}"
          value="{{form.arrival_date}}"
          readonly
          is-link
        />
      </view>
      <view bindtap="openTerminalPicker">
        <van-field
          label="{{i18n.student_request_terminal_label}}"
          placeholder="{{i18n.student_request_terminal_placeholder}}"
          value="{{form.terminal}}"
          readonly
          is-link
        />
      </view>
      <view bindtap="openTimePicker">
        <van-field
          label="{{i18n.student_request_time_label}}"
          placeholder="{{i18n.student_request_time_placeholder}}"
          value="{{form.arrival_time}}"
          readonly
          is-link
        />
      </view>
      <view class="stepper-row">
        <text class="stepper-label">{{i18n.student_request_checked_label}}</text>
        <van-stepper value="{{form.checked_bags}}" min="0" max="10" bind:change="onStepperCheckedChange" bind:overlimit="onBagsOverLimit" />
      </view>
      <view class="stepper-row">
        <text class="stepper-label">{{i18n.student_request_carryon_label}}</text>
        <van-stepper value="{{form.carry_on_bags}}" min="0" max="10" bind:change="onStepperCarryOnChange" bind:overlimit="onBagsOverLimit" />
      </view>
      <van-field
        label="{{i18n.student_request_ridewith_label}}"
        type="textarea"
        autosize
        maxlength="200"
        placeholder="{{i18n.student_request_ridewith_placeholder}}"
        value="{{form.ride_with_note}}"
        data-field="ride_with_note"
        bind:change="onFieldChange"
      />
      <van-field
        label="{{i18n.student_request_wechat_label}}"
        maxlength="20"
        placeholder="{{i18n.student_request_wechat_placeholder}}"
        value="{{form.ride_with_wechat}}"
        data-field="ride_with_wechat"
        bind:change="onFieldChange"
      />
    </van-cell-group>

    <van-button
      type="primary"
      block
      loading="{{submitting}}"
      custom-style="margin-top: 24rpx;"
      bind:tap="onSubmit"
    >{{i18n.student_request_submit}}</van-button>
  </view>

  <view class="card" wx:else>
    <view class="section-title">{{i18n.student_request_title}}</view>
    <view class="submit-locked">{{i18n.student_request_submitted_lock}}</view>
  </view>

  <view class="card tracker-card">
    <view class="section-title">{{i18n.student_request_track_title}}</view>

    <view wx:if="{{loadingTrack}}">
      <van-skeleton title row="3" />
    </view>

    <view wx:elif="{{!latestRequest}}">
      <van-empty description="{{i18n.student_request_no_record}}" />
    </view>

    <view wx:else>
      <van-steps steps="{{trackSteps}}" active="{{activeStep}}" direction="horizontal" />

      <!-- 申请信息卡片 -->
      <view class="info-card card-inner">
        <view class="inner-title">{{i18n.request_info_title}}</view>

        <!-- 非编辑模式：只读展示 -->
        <block wx:if="{{!editing}}">
          <view class="line">{{i18n.request_info_flight}}{{latestRequest.flight_no}}</view>
          <view class="line">{{i18n.request_info_arrival}}{{formattedArrivalTime || '--'}}</view>
          <view class="line">{{i18n.request_info_terminal}}{{latestRequest.terminal || '--'}}</view>
          <view class="line">{{i18n.request_info_bags}}{{latestRequest.checked_bags}}{{i18n.request_info_bags_sep}}{{latestRequest.carry_on_bags}}{{i18n.request_info_bags_unit}}</view>
          <view wx:if="{{latestRequest.ride_with_wechat}}" class="line">{{i18n.request_info_wechat}}{{latestRequest.ride_with_wechat}}</view>
          <view wx:if="{{latestRequest.ride_with_note}}" class="line">{{i18n.request_info_note}}{{latestRequest.ride_with_note}}</view>
        </block>

        <!-- 编辑模式（仅 pending 状态） -->
        <block wx:if="{{editing}}">
          <van-cell-group inset>
            <van-field
              label="{{i18n.student_request_flight_label}}"
              value="{{editForm.flight_no}}"
              data-field="flight_no"
              bind:change="onEditFieldChange"
            />
            <view bindtap="openEditDatePicker">
              <van-field
                label="{{i18n.student_request_date_label}}"
                value="{{editForm.arrival_date}}"
                readonly
                is-link
              />
            </view>
            <view bindtap="openEditTerminalPicker">
              <van-field
                label="{{i18n.student_request_terminal_label}}"
                value="{{editForm.terminal}}"
                readonly
                is-link
              />
            </view>
            <view bindtap="openEditTimePicker">
              <van-field
                label="{{i18n.student_request_time_label}}"
                value="{{editForm.arrival_time}}"
                readonly
                is-link
              />
            </view>
            <view class="stepper-row">
              <text class="stepper-label">{{i18n.student_request_checked_label}}</text>
              <van-stepper value="{{editForm.checked_bags}}" min="0" max="10" bind:change="onEditCheckedChange" />
            </view>
            <view class="stepper-row">
              <text class="stepper-label">{{i18n.student_request_carryon_label}}</text>
              <van-stepper value="{{editForm.carry_on_bags}}" min="0" max="10" bind:change="onEditCarryOnChange" />
            </view>
            <van-field
              label="{{i18n.student_request_ridewith_label}}"
              type="textarea"
              autosize
              maxlength="200"
              value="{{editForm.ride_with_note}}"
              data-field="ride_with_note"
              bind:change="onEditFieldChange"
            />
            <van-field
              label="{{i18n.student_request_wechat_label}}"
              maxlength="20"
              value="{{editForm.ride_with_wechat}}"
              data-field="ride_with_wechat"
              bind:change="onEditFieldChange"
            />
          </van-cell-group>
          <view class="edit-actions">
            <van-button type="primary" block loading="{{savingEdit}}" bind:tap="saveEdit" custom-style="margin-top: 16rpx;">{{i18n.request_edit_save}}</van-button>
            <van-button type="default" block bind:tap="cancelEdit" custom-style="margin-top: 12rpx;">{{i18n.request_edit_cancel}}</van-button>
          </view>
        </block>

        <!-- 修改次数 & pending 编辑按钮 -->
        <view wx:if="{{latestRequest.modification_count > 0}}" class="line mod-count">{{i18n.mod_count_label}}{{latestRequest.modification_count}} / 3</view>
        <van-button
          wx:if="{{latestRequest.status === 'pending' && !editing}}"
          type="warning"
          plain
          block
          custom-style="margin-top: 16rpx;"
          bind:tap="editRequest"
        >{{i18n.request_edit_btn}}</van-button>
      </view>

      <view class="latest">
        <van-tag type="primary" plain>{{latestRequest.status_text || latestRequest.status}}</van-tag>
      </view>

      <view wx:if="{{assignedShift}}" class="assigned card-inner">
        <view class="inner-title">{{i18n.student_request_assigned_title}}</view>
        <view class="line">{{i18n.student_request_driver_label}}{{assignedShift.driver.name || '--'}}</view>
        <view class="line">{{i18n.student_request_car_label}}{{assignedShift.driver.car_model || '--'}}</view>
        <view class="line">{{i18n.student_request_meetpoint_label}}{{latestRequest.terminal || '--'}}</view>
        <view class="line">{{i18n.student_request_depart_label}}{{assignedShift.departure_time || '--'}}</view>
        
        <!-- 登车状态 -->
        <view class="line boarding-status-line">
          <text wx:if="{{latestRequest.boarded_at}}" class="boarding-tag boarded">✅ {{i18n.student_request_boarded || '已登车'}}</text>
          <text wx:else class="boarding-tag waiting">⏳ {{i18n.student_request_waiting_board || '待登车'}}</text>
        </view>
        
        <!-- 登车二维码 -->
        <view class="qr-code-section">
          <view class="inner-title">{{i18n.student_request_qr_title}}</view>
          <view class="qr-code-tips">{{i18n.student_request_qr_tips}}</view>
          
          <view wx:if="{{generatingQrCode}}" class="qr-code-loading">
            <van-loading size="24px">{{i18n.student_request_qr_generating}}</van-loading>
          </view>
          
          <view wx:elif="{{qrCodePath}}" class="qr-code-container">
            <image src="{{qrCodePath}}" class="qr-code-image" mode="widthFix" />
            <view class="qr-code-actions">
              <van-button 
                type="primary" 
                size="small" 
                bindtap="openQrCodeModal"
              >
                {{i18n.student_request_qr_view}}
              </van-button>
              <van-button 
                type="default" 
                size="small" 
                bindtap="saveQrCodeToAlbum"
              >
                {{i18n.student_request_qr_save}}
              </van-button>
            </view>
          </view>
          
          <view wx:else class="qr-code-empty">
            <van-empty description="{{qrCodeError || i18n.student_request_qr_failed}}" mode="list" />
            <view wx:if="{{qrCodeError}}" class="qr-code-error">{{qrCodeError}}</view>
          </view>
        </view>
      </view>

      <!-- 申请修改按钮（非 pending 状态显示） -->
      <view wx:if="{{latestRequest.status !== 'pending'}}" class="mod-request-section">
        <view wx:if="{{modRequestStatus === 'pending'}}" class="mod-request-pending">
          <van-tag type="warning" size="medium">{{i18n.mod_request_pending}}</van-tag>
        </view>
        <van-button
          wx:else
          type="warning"
          plain
          block
          custom-style="margin-top: 24rpx;"
          bind:tap="goToModification"
        >{{i18n.mod_request_btn}}</van-button>
      </view>
    </view>
  </view>

  <!-- 隐藏的canvas用于生成二维码 -->
  <block wx:if="{{showQrCanvas}}">
    <canvas 
      id="qrCodeCanvas" 
      style="position: absolute; left: -9999rpx; width: 200px; height: 200px;" 
      type="2d"
    />
    <canvas
      id="qrCodeCanvasLegacy"
      canvas-id="qrCodeCanvasLegacy"
      style="position: absolute; left: -9999rpx; width: 200px; height: 200px;"
    />
  </block>

  <van-action-sheet
    show="{{showTerminalPicker}}"
    title="{{i18n.student_request_terminal_title}}"
    actions="{{terminalActions}}"
    close-on-click-action="true"
    bind:select="onSelectTerminal"
    bind:close="onCloseTerminalPicker"
  />

  <van-calendar
    show="{{showDatePicker}}" min-date="{{calendarMinDate}}" max-date="{{calendarMaxDate}}"
    type="single"
    bind:close="onDatePickerClose"
    bind:confirm="onDateConfirm"
  />

  <van-popup show="{{showTimePicker}}" position="bottom" bind:close="onTimePickerCancel">
    <van-datetime-picker
      type="time"
      value="{{timePickerValue}}"
      title="{{i18n.student_request_time_title}}"
      bind:cancel="onTimePickerCancel"
      bind:confirm="onTimeConfirm"
    />
  </van-popup>

  <!-- 二维码大图模态框 -->
  <van-popup 
    show="{{showQrCodeModal}}" 
    position="center" 
    round
    bind:close="closeQrCodeModal"
  >
    <view class="qr-code-modal">
      <view class="modal-header">
        <text class="modal-title">{{i18n.student_request_qr_modal_title}}</text>
        <van-icon name="cross" size="18px" bindtap="closeQrCodeModal" />
      </view>
      
      <view class="modal-content">
        <view wx:if="{{qrCodePath}}" class="large-qr-code">
          <image src="{{qrCodePath}}" class="qr-code-large-image" mode="widthFix" />
          <view class="qr-code-instruction">
            {{i18n.student_request_qr_instruction}}
          </view>
        </view>
        
        <view class="modal-actions">
          <van-button 
            type="primary" 
            block
            bindtap="saveQrCodeToAlbum"
          >
            {{i18n.student_request_qr_save}}
          </van-button>
        </view>
      </view>
    </view>
  </van-popup>


</view>
