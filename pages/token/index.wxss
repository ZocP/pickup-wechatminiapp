.token-page {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 48rpx;
  box-sizing: border-box;
}

.token-container {
  width: 100%;
  max-width: 600rpx;
  text-align: center;
}

.token-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.token-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #323233;
  margin-bottom: 12rpx;
}

.token-desc {
  font-size: 26rpx;
  color: #969799;
  margin-bottom: 48rpx;
}

.token-input-wrap {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.token-error {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #ee0a24;
}
