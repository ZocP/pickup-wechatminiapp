.dispatch-page {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 120rpx;
}

.date-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
}

.nav-btn {
  width: auto !important;
  min-width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 32rpx;
  color: #323233;
  background: #f2f3f5;
  border: none;
  border-radius: 8rpx;
  padding: 0 16rpx;
  text-align: center;
}

.nav-btn[disabled] {
  color: #c8c9cc;
  background: #f7f8fa;
}

.date-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  padding: 0 16rpx;
}

.today-btn {
  width: auto !important;
  min-width: 100rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #1989fa;
  background: #ecf5ff;
  border: none;
  border-radius: 8rpx;
  padding: 0 16rpx;
}

.shift-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #f2f3f5;
}

.shift-label {
  font-size: 28rpx;
  color: #646566;
  text-align: center;
}

.shift-time {
  font-size: 24rpx;
  color: #969799;
}

.card {
  margin: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
}

.vehicle-list {
  padding: 24rpx;
}

.action-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  width: auto !important;
}
