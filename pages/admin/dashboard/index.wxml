<view class="page dashboard-page">
  <view class="summary card">
    <van-grid column-num="3" border="false">
      <van-grid-item use-slot>
        <view class="summary-item">
          <text class="summary-label">{{i18n.dashboard_pending_count_label}}</text>
          <text class="grid-number danger">{{pendingCount}}</text>
        </view>
      </van-grid-item>
      <van-grid-item use-slot>
        <view class="summary-item">
          <text class="summary-label">{{i18n.dashboard_today_shifts_label}}</text>
          <text class="grid-number">{{todayShiftCount}}</text>
        </view>
      </van-grid-item>
      <van-grid-item use-slot>
        <view class="summary-item">
          <text class="summary-label">{{i18n.dashboard_published_count_label}}</text>
          <text class="grid-number success">{{publishedCount}}</text>
        </view>
      </van-grid-item>
    </van-grid>
  </view>

  <view class="create-entry card">
    <van-button type="info" block bind:tap="onShowCreatePopup">{{i18n.dashboard_add_shift}}</van-button>
    <van-button type="warning" block custom-style="margin-top: 16rpx;" bind:tap="onQuickAssign">{{i18n.dashboard_quick_assign}}</van-button>
  </view>

  <!-- 日期筛选栏 -->
  <view class="date-filter-bar">
    <button class="filter-nav-btn" bindtap="filterPrevDay">‹</button>
    <view class="filter-date-label" bindtap="filterPickDate">
      <text>{{filterDateLabel}}</text>
    </view>
    <button class="filter-nav-btn" bindtap="filterNextDay">›</button>
    <button class="filter-action-btn{{filterDate == todayDate ? ' active' : ''}}" bindtap="filterToday">{{i18n.today}}</button>
    <button class="filter-action-btn{{!filterDate ? ' active' : ''}}" bindtap="filterReset">{{i18n.all}}</button>
  </view>

  <view class="shift-list">
    <view wx:if="{{loading}}" class="card">
      <van-skeleton title row="3" />
      <van-skeleton title row="3" custom-style="margin-top: 16rpx;" />
    </view>

    <view wx:if="{{!loading && shifts.length === 0}}" class="card">
      <van-empty description="{{i18n.dashboard_no_shifts}}" />
    </view>

    <shift-card
      wx:for="{{!loading ? shifts : []}}"
      wx:key="id"
      shift="{{item}}"
      bind:manageshift="onManageShift"
    />
  </view>

  <view class="pending-fab" bind:tap="openPendingPool">
    <text>{{i18n.dashboard_pending_pool_label}} {{pendingCount}}</text>
  </view>
  <view wx:if="{{pendingActionOverflow > 0}}" class="card" style="margin-top: 16rpx;">
    <text style="font-size: 24rpx; color: #999;">{{overflowTipText}}</text>
  </view>

  <van-action-sheet
    show="{{showPendingSheet}}"
    title="{{i18n.dashboard_pending_students}}"
    z-index="2000"
    root-portal
    actions="{{pendingActions}}"
    close-on-click-action="true"
    bind:select="onSelectPendingRequest"
    bind:close="onClosePendingSheet"
  />

  <van-action-sheet
    show="{{showShiftPicker}}"
    title="{{i18n.dashboard_select_shift}}"
    z-index="2000"
    root-portal
    actions="{{shiftActions}}"
    close-on-click-action="true"
    bind:select="onSelectShift"
    bind:close="onCloseShiftPicker"
  />

  <van-action-sheet
    show="{{showRemoveSheet}}"
    title="{{i18n.dashboard_remove_passenger_title}}"
    z-index="2000"
    root-portal
    actions="{{removeActions}}"
    close-on-click-action="true"
    bind:select="onSelectRemoveRequest"
    bind:close="onCloseRemoveSheet"
  />

  <van-popup show="{{showCreatePopup}}" position="bottom" round bind:close="onCloseCreatePopup">
    <view class="create-popup">
      <view class="create-title">{{i18n.dashboard_create_shift_title}}</view>
      <van-cell-group inset>
        <van-field
          label="{{i18n.dashboard_field_driver}}"
          value="{{selectedDriverName}}"
          placeholder="{{i18n.dashboard_placeholder_driver}}"
          readonly
          is-link
          bind:click-input="onOpenDriverPicker"
        />
        <van-field
          label="{{i18n.dashboard_field_date}}"
          value="{{selectedDate}}"
          placeholder="{{i18n.dashboard_placeholder_date}}"
          readonly
          is-link
          bind:click-input="onOpenDatePicker"
        />
        <van-field
          label="{{i18n.dashboard_field_time}}"
          value="{{selectedClock}}"
          placeholder="{{i18n.dashboard_placeholder_time}}"
          readonly
          is-link
          bind:click-input="onOpenTimePicker"
        />
      </van-cell-group>
      <van-button type="info" block custom-style="margin-top: 24rpx;" bind:tap="onSubmitShift">{{i18n.dashboard_confirm_create}}</van-button>
    </view>
  </van-popup>

  <van-popup show="{{showDriverPicker}}" position="bottom" bind:close="onCancelDriverPicker">
    <van-picker
      title="{{i18n.dashboard_field_driver}}"
      show-toolbar
      columns="{{pickerColumns}}"
      bind:confirm="onConfirmDriver"
      bind:cancel="onCancelDriverPicker"
    />
  </van-popup>

  <van-popup show="{{showDatePicker}}" position="bottom" z-index="2000" root-portal bind:close="onCancelDatePicker">
    <van-datetime-picker
      type="date"
      title="{{i18n.dashboard_field_date}}"
      show-toolbar
      min-date="{{minDateTs}}"
      value="{{selectedDateTs}}"
      bind:confirm="onConfirmDate"
      bind:cancel="onCancelDatePicker"
    />
  </van-popup>

  <van-popup show="{{showTimePicker}}" position="bottom" z-index="2000" root-portal bind:close="onCancelTimePicker">
    <van-datetime-picker
      type="time"
      title="{{i18n.dashboard_field_time}}"
      show-toolbar
      value="{{selectedClock}}"
      bind:confirm="onConfirmTime"
      bind:cancel="onCancelTimePicker"
    />
  </van-popup>

  <van-calendar
    show="{{showCalendar}}"
    bind:confirm="onCalendarConfirm"
    bind:close="onCalendarClose"
    type="single"
    default-date="{{calendarDefaultDate}}"
  />
</view>