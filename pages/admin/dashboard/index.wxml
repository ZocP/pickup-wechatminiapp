<view class="page dashboard-page">
  <!-- 角色模拟状态条 -->
  <view wx:if="{{realRole === 'admin'}}" class="role-simulation-bar card">
    <view class="role-bar-content">
      <view class="role-info">
        <text class="role-label">当前视角：</text>
        <text class="role-value {{isViewingAsUser ? 'simulating' : 'admin'}}">
          {{isViewingAsUser ? '模拟中 (' + getRoleDisplayText() + ')' : '管理员'}}
        </text>
      
  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
    show="{{showRoleSimulator}}"
    title="选择模拟角色"
    z-index="2000"
    root-portal
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="onCloseRoleSimulator"
  />
</view>
      <view class="role-actions">
        <van-button 
          wx:if="{{isViewingAsUser}}" 
          type="warning" 
          size="small" 
          bind:tap="onExitRoleSimulation"
        >
          退出模拟
        </van-button>
        <van-button 
          type="primary" 
          size="small" 
          bind:tap="onOpenRoleSimulator"
        >
          {{isViewingAsUser ? '切换角色' : '角色模拟'}}
        </van-button>
      
  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
    show="{{showRoleSimulator}}"
    title="选择模拟角色"
    z-index="2000"
    root-portal
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="onCloseRoleSimulator"
  />
</view>
    
  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
