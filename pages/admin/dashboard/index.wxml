  <view class="create-entry card">
    <van-button type="info" block bind:tap="onShowCreatePopup">添加班次</van-button>
  
  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
    show="{{showRoleSimulator}}"
    title="选择模拟角色"
    z-index="2000"
    root-portal
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="onCloseRoleSimulator"
  />
</view>

  <view class="shift-list">
    <view wx:if="{{loading}}" class="card">
      <van-skeleton title row="3" />
      <van-skeleton title row="3" custom-style="margin-top: 16rpx;" />
    
  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
    show="{{showRoleSimulator}}"
    title="选择模拟角色"
    z-index="2000"
    root-portal
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="onCloseRoleSimulator"
  />
</view>

    <view wx:if="{{!loading && shifts.length === 0}}" class="card">
      <van-empty description="暂无班次数据" />
    
  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
    show="{{showRoleSimulator}}"
    title="选择模拟角色"
    z-index="2000"
    root-portal
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="onCloseRoleSimulator"
  />
</view>

    <shift-card
      wx:for="{{!loading ? shifts : []}}"
      wx:key="id"
      shift="{{item}}"
      bind:manageshift="onManageShift"
    />
  
  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
    show="{{showRoleSimulator}}"
    title="选择模拟角色"
    z-index="2000"
    root-portal
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="onCloseRoleSimulator"
  />
</view>

  <view class="pending-fab" bind:tap="openPendingPool">
    <text>待分配池 {{pendingCount}}</text>
  
  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
    show="{{showRoleSimulator}}"
    title="选择模拟角色"
    z-index="2000"
    root-portal
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="onCloseRoleSimulator"
  />
</view>
  <view wx:if="{{pendingActionOverflow > 0}}" class="card" style="margin-top: 16rpx;">
    <text style="font-size: 24rpx; color: #999;">待分配人数较多，弹层仅展示前 {{pendingActions.length}} 条。</text>
  
  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
    show="{{showRoleSimulator}}"
    title="选择模拟角色"
    z-index="2000"
    root-portal
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="onCloseRoleSimulator"
  />
</view>

  <van-action-sheet
    show="{{showPendingSheet}}"
    title="待分配学生"
    z-index="2000"
    root-portal
    actions="{{pendingActions}}"
    close-on-click-action="true"
    bind:select="onSelectPendingRequest"
    bind:close="onClosePendingSheet"
  />

  <van-action-sheet
    show="{{showShiftPicker}}"
    title="选择班次"
    z-index="2000"
    root-portal
    actions="{{shiftActions}}"
    close-on-click-action="true"
    bind:select="onSelectShift"
    bind:close="onCloseShiftPicker"
  />

  <van-action-sheet
    show="{{showRemoveSheet}}"
    title="选择要移出的乘客"
    z-index="2000"
    root-portal
    actions="{{removeActions}}"
    close-on-click-action="true"
    bind:select="onSelectRemoveRequest"
    bind:close="onCloseRemoveSheet"
  />

  <van-popup show="{{showCreatePopup}}" position="bottom" round bind:close="onCloseCreatePopup">
    <view class="create-popup">
      <view class="create-title">创建班次
  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
    show="{{showRoleSimulator}}"
    title="选择模拟角色"
    z-index="2000"
    root-portal
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="onCloseRoleSimulator"
  />
</view>
      <van-cell-group inset>
        <van-field
          label="选择司机"
          value="{{selectedDriverName}}"
          placeholder="请选择司机"
          readonly
          is-link
          bind:click-input="onOpenDriverPicker"
        />
        <van-field
          label="发车日期"
          value="{{selectedDate}}"
          placeholder="请选择日期"
          readonly
          is-link
          bind:click-input="onOpenDatePicker"
        />
        <van-field
          label="发车时刻"
          value="{{selectedClock}}"
          placeholder="请选择时间"
          readonly
          is-link
          bind:click-input="onOpenTimePicker"
        />
      </van-cell-group>
      <van-button type="info" block custom-style="margin-top: 24rpx;" bind:tap="onSubmitShift">确认创建</van-button>
    
  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
    show="{{showRoleSimulator}}"
    title="选择模拟角色"
    z-index="2000"
    root-portal
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="onCloseRoleSimulator"
  />
</view>
  </van-popup>

  <van-popup show="{{showDriverPicker}}" position="bottom" bind:close="onCancelDriverPicker">
    <van-picker
      title="选择司机"
      show-toolbar
      columns="{{pickerColumns}}"
      bind:confirm="onConfirmDriver"
      bind:cancel="onCancelDriverPicker"
    />
  </van-popup>

  <van-popup show="{{showDatePicker}}" position="bottom" bind:close="onCancelDatePicker">
    <van-datetime-picker
      type="date"
      title="发车日期"
      show-toolbar
      min-date="{{minDateTs}}"
      value="{{selectedDateTs}}"
      bind:confirm="onConfirmDate"
      bind:cancel="onCancelDatePicker"
    />
  </van-popup>

  <van-popup show="{{showTimePicker}}" position="bottom" bind:close="onCancelTimePicker">
    <van-datetime-picker
      type="time"
      title="发车时刻"
      show-toolbar
      value="{{selectedClock}}"
      bind:confirm="onConfirmTime"
      bind:cancel="onCancelTimePicker"
    />
  </van-popup>

  <!-- 角色模拟选择弹窗 -->
  <van-action-sheet
    show="{{showRoleSimulator}}"
    title="选择模拟角色"
    z-index="2000"
    root-portal
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="onCloseRoleSimulator"
  />
</view>
