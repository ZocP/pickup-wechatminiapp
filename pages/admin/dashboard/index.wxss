.dashboard-page {
  padding: 20rpx;
  padding-bottom: 140rpx;
  overflow-x: hidden;
}

/* 角色模拟状态条样式 */
.role-simulation-bar {
  margin-bottom: 18rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.role-bar-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
}

.role-info {
  display: flex;
  flex-direction: column;
}

.role-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.role-value {
  font-size: 32rpx;
  font-weight: 700;
}

.role-value.admin {
  color: #4cd964;
}

.role-value.simulating {
  color: #ffcc00;
}

.role-actions {
  display: flex;
  gap: 16rpx;
}

.role-actions van-button {
  min-width: 140rpx;
}

.summary {
  margin-bottom: 18rpx;
}

.summary-item {
  height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.summary-label {
  font-size: 24rpx;
  color: #969799;
}

.create-entry {
  margin-bottom: 18rpx;
}

.grid-number {
  font-size: 44rpx;
  font-weight: 700;
  color: #323233;
  margin-top: 6rpx;
}

.grid-number.danger {
  color: #ee0a24;
}

.grid-number.success {
  color: #07c160;
}

.pending-fab {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #1989fa;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 26rpx rgba(25, 137, 250, 0.35);
}

.create-popup {
  padding: 24rpx;
  padding-bottom: 34rpx;
}

.create-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.shift-list .card {
  border: 1rpx solid #edf3ff;
}

/* 日期筛选栏 */
.date-filter-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  padding: 12rpx 24rpx;
  gap: 12rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.filter-nav-btn {
  flex-shrink: 0;
  width: 48rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0;
  font-size: 28rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  border: none;
  color: #333;
}
.filter-nav-btn::after { border: none; }
.filter-date-label {
  flex: 1;
  min-width: 160rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  height: 56rpx;
  line-height: 56rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  background: #f5f5f5;
  border-radius: 8rpx;
}
.filter-action-btn {
  flex-shrink: 0;
  min-width: 80rpx;
  padding: 0 16rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  border: none;
  color: #666;
  white-space: nowrap;
}
.filter-action-btn::after { border: none; }
.filter-action-btn.active {
  background: #1989fa;
  color: #fff;
}
