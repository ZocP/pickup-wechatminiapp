.dashboard-page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.summary {
  margin-bottom: 18rpx;
}

.summary-item {
  height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.summary-label {
  font-size: 24rpx;
  color: #969799;
}

.create-entry {
  margin-bottom: 18rpx;
}

.grid-number {
  font-size: 44rpx;
  font-weight: 700;
  color: #323233;
  margin-top: 6rpx;
}

.grid-number.danger {
  color: #ee0a24;
}

.grid-number.success {
  color: #07c160;
}

.pending-fab {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #1989fa;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 26rpx rgba(25, 137, 250, 0.35);
}

.create-popup {
  padding: 24rpx;
  padding-bottom: 34rpx;
}

.create-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}
