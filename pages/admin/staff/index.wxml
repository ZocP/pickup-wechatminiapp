<view class="page staff-page">
	<view class="card">
		<view class="section-title">用户角色管理</view>

		<view wx:if="{{!loading && userList.length === 0}}">
			<van-empty description="暂无用户数据" />
		</view>

		<van-cell-group inset wx:else>
			<van-cell wx:for="{{userList}}" wx:key="id" title="{{item.name || ('用户#' + item.id)}}" center use-slot use-label-slot>
				<view slot="label" class="cell-label">
					<text class="cell-wechat">微信号：{{item.wechat_id || '--'}}</text>
					<van-tag
						type="{{item.role === 'admin' ? 'danger' : (item.role === 'staff' ? 'success' : (item.role === 'driver' ? 'warning' : 'primary'))}}"
						plain
						size="medium"
						custom-style="padding: 2rpx 10rpx; font-size: 22rpx; margin-top: 6rpx;"
					>{{item.role || 'student'}}</van-tag>
				</view>
				<view class="right-wrap">
					<van-button
						wx:if="{{item.role !== 'admin'}}"
						size="small"
						type="primary"
						plain
						custom-style="height: 48rpx; min-width: 120rpx; padding: 0 20rpx; font-size: 24rpx;"
						loading="{{actingUserId === item.id}}"
						data-id="{{item.id}}"
						data-role="{{item.role}}"
						bind:click="onOpenRoleActions"
					>操作</van-button>
				</view>
			</van-cell>
		</van-cell-group>
	</view>

  <van-action-sheet
    show="{{showRoleActions}}"
    title="用户操作"
    actions="{{roleActions}}"
    close-on-click-action="true"
    bind:select="onSelectRoleAction"
    bind:close="onCloseRoleActions"
  />

  <van-action-sheet
    show="{{showDriverPicker}}"
    title="选择司机档案"
    actions="{{driverActions}}"
    close-on-click-action="true"
    bind:select="onSelectDriver"
    bind:close="onCloseDriverPicker"
  />
</view>
