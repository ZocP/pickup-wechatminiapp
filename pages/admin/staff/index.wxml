<view class="page staff-page">
	<van-search
		value="{{searchKeyword}}"
		placeholder="{{i18n.staff_search_placeholder}}"
		bind:change="onSearchChange"
		bind:clear="onSearchClear"
	/>
	<view wx:if="{{searchKeyword}}" class="search-result-count">
		<text>{{i18n.staff_search_result_count}}{{filteredUserList.length}}</text>
	</view>

	<view class="card">
		<view class="section-title">{{i18n.staff_role_management}}</view>

		<view wx:if="{{!loading && filteredUserList.length === 0}}">
			<van-empty description="{{i18n.staff_no_users}}" />
		</view>

		<van-cell-group inset wx:else>
			<van-cell wx:for="{{filteredUserList}}" wx:key="id" title="{{item.name || (i18n.common_student_prefix + item.id)}}" center use-slot use-label-slot>
				<view slot="label" class="cell-label">
					<text class="cell-wechat">{{i18n.staff_wechat_label}}{{item.wechat_id || '--'}}</text>
					<van-tag
						type="{{item.role === 'admin' ? 'danger' : (item.role === 'staff' ? 'success' : (item.role === 'driver' ? 'warning' : 'primary'))}}"
						plain
						size="medium"
						custom-style="padding: 2rpx 10rpx; font-size: 22rpx; margin-top: 6rpx;"
					>{{item.role || 'student'}}</van-tag>
				</view>
				<view class="right-wrap">
					<van-button
						size="small"
						type="primary"
						plain
						custom-style="height: 56rpx; width: 120rpx; padding: 0; font-size: 24rpx;"
						loading="{{actingUserId === item.id}}"
						data-id="{{item.id}}"
						data-role="{{item.role}}"
						bind:click="onOpenRoleActions"
					>{{i18n.staff_operate}}</van-button>
				</view>
			</van-cell>
		</van-cell-group>
	</view>

  <van-action-sheet
    show="{{showRoleActions}}"
    title="{{i18n.staff_role_actions_title}}"
    actions="{{roleActions}}"
    close-on-click-action="true"
    bind:select="onSelectRoleAction"
    bind:close="onCloseRoleActions"
  />

  <van-action-sheet
    show="{{showDriverPicker}}"
    title="{{i18n.staff_driver_picker_title}}"
    actions="{{driverActions}}"
    close-on-click-action="true"
    bind:select="onSelectDriver"
    bind:close="onCloseDriverPicker"
  />
</view>
