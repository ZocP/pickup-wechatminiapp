.detail-page {
  padding: 24rpx;
  padding-bottom: 180rpx;
}

.card {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.edit-btn-wrap {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.stepper-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #f1f3f5;
}

.stepper-label {
  font-size: 28rpx;
  color: #323233;
}

.shift-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #969799;
}

.delete-wrap {
  padding: 24rpx;
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.loading-wrap {
  padding-top: 200rpx;
}
