<view class="page detail-page" wx:if="{{!loading}}">
  <!-- 基本信息区 -->
  <view class="card">
    <view class="section-title">{{i18n.driver_detail_info}}</view>
    <van-cell-group inset>
      <van-cell title="{{i18n.driver_detail_name}}" value="{{driver.name}}" />
      <van-cell title="{{i18n.driver_detail_phone}}" value="{{driver.phone || '--'}}" />
      <van-cell title="{{i18n.driver_detail_car_model}}" value="{{driver.car_model || '--'}}" />
      <van-cell title="{{i18n.driver_detail_car_plate}}" value="{{driver.car_plate || '--'}}" />
      <van-cell title="{{i18n.driver_detail_car_color}}" value="{{driver.car_color || '--'}}" />
      <van-cell title="{{i18n.driver_detail_max_seats}}" value="{{driver.max_seats}}" />
      <van-cell title="{{i18n.driver_detail_max_checked}}" value="{{driver.max_checked}}" />
      <van-cell title="{{i18n.driver_detail_max_carry_on}}" value="{{driver.max_carry_on}}" />
    </van-cell-group>
    <view class="edit-btn-wrap">
      <van-button plain type="info" size="small" bind:tap="toggleEdit">
        {{editing ? i18n.driver_detail_cancel : i18n.driver_detail_edit}}
      </van-button>
    </view>
  </view>

  <!-- 编辑表单 -->
  <view class="card" wx:if="{{editing}}">
    <view class="section-title">{{i18n.driver_detail_edit_title}}</view>
    <van-field
      label="{{i18n.driver_detail_car_model}}"
      value="{{form.car_model}}"
      data-field="car_model"
      bind:change="onFormChange"
    />
    <van-field
      label="{{i18n.driver_detail_car_plate}}"
      value="{{form.car_plate}}"
      data-field="car_plate"
      bind:change="onFormChange"
    />
    <van-field
      label="{{i18n.driver_detail_car_color}}"
      value="{{form.car_color}}"
      data-field="car_color"
      bind:change="onFormChange"
    />
    <view class="stepper-row">
      <text class="stepper-label">{{i18n.driver_detail_max_seats}}</text>
      <van-stepper min="1" value="{{form.max_seats}}" bind:change="onMaxSeatsChange" />
    </view>
    <view class="stepper-row">
      <text class="stepper-label">{{i18n.driver_detail_max_checked}}</text>
      <van-stepper min="0" value="{{form.max_checked}}" bind:change="onMaxCheckedChange" />
    </view>
    <view class="stepper-row">
      <text class="stepper-label">{{i18n.driver_detail_max_carry_on}}</text>
      <van-stepper min="0" value="{{form.max_carry_on}}" bind:change="onMaxCarryOnChange" />
    </view>
    <van-button type="info" block loading="{{saving}}" custom-style="margin-top: 24rpx;" bind:tap="onSave">
      {{i18n.driver_detail_save}}
    </van-button>
  </view>

  <!-- 班次列表 -->
  <view class="card">
    <view class="section-title">{{i18n.driver_detail_shifts}}</view>
    <view wx:if="{{!driver.shifts || driver.shifts.length === 0}}">
      <van-empty description="{{i18n.driver_detail_no_shifts}}" />
    </view>
    <van-cell-group inset wx:else>
      <van-cell
        wx:for="{{driver.shifts}}"
        wx:key="id"
        title="{{item.departure_time_fmt}}"
      >
        <view slot="right-icon" class="shift-meta">
          <van-tag type="{{item.status === 'published' ? 'success' : 'default'}}">{{item.status}}</van-tag>
          <text class="meta-text">👥 {{item.passenger_count}} / {{item.capacity}}</text>
        </view>
      </van-cell>
    </van-cell-group>
  </view>

  <!-- 删除按钮 -->
  <view class="delete-wrap">
    <van-button type="danger" block loading="{{deleting}}" bind:tap="onDelete">
      {{i18n.driver_detail_delete}}
    </van-button>
  </view>

  <van-dialog id="van-dialog" />
</view>

<view wx:else class="loading-wrap">
  <van-empty description="{{i18n.driver_detail_loading}}" />
</view>
