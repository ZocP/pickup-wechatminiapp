<view class="page shift-detail-page">
  <van-sticky>
    <view class="header-card">
      <view class="header-row-base">
        <view class="header-time">{{headerTime}}</view>
        <van-tag type="{{statusTagType}}" plain>{{statusText}}</van-tag>
      </view>
      <view class="header-row-meta">
        <view class="header-driver">{{i18n.shift_detail_driver_prefix}}{{driverText}}</view>
        <van-tag plain type="primary" size="medium">{{terminalRoute || i18n.shift_detail_no_route}}</van-tag>
      </view>

      <view class="resource-block">
        <view class="resource-line">
          <text class="resource-label">{{i18n.shift_detail_seats}}</text>
          <view class="resource-progress">
            <van-progress percentage="{{seatUsage.percent}}" color="{{seatUsage.color}}" pivot-text="" show-pivot="false" stroke-width="8" />
          </view>
          <text class="resource-value">{{seatUsage.used}} / {{seatUsage.max}}</text>
        </view>

        <view class="resource-line">
          <text class="resource-label">{{i18n.shift_detail_checked}}</text>
          <view class="resource-progress">
            <van-progress percentage="{{checkedUsage.percent}}" color="{{checkedUsage.color}}" pivot-text="" show-pivot="false" stroke-width="8" />
          </view>
          <text class="resource-value">{{checkedUsage.used}} / {{checkedUsage.max}}</text>
        </view>

        <view class="resource-line">
          <text class="resource-label">{{i18n.shift_detail_carry_on}}</text>
          <view class="resource-progress">
            <van-progress percentage="{{carryOnUsage.percent}}" color="{{carryOnUsage.color}}" pivot-text="" show-pivot="false" stroke-width="8" />
          </view>
          <text class="resource-value">{{carryOnUsage.used}} / {{carryOnUsage.max}}</text>
        </view>

        <!-- 登车状态 -->
        <view class="resource-line boarding-status-line" wx:if="{{boardedCount !== undefined && unboardedCount !== undefined}}">
          <text class="resource-label">{{i18n.shift_detail_boarding}}</text>
          <view class="boarding-status-values">
            <text class="boarding-count boarded">{{boardedCount}} {{i18n.shift_detail_boarded_suffix}}</text>
            <text class="boarding-count unboarded">{{unboardedCount}} {{i18n.shift_detail_unboarded_suffix}}</text>
          </view>
        </view>
      </view>
    </view>
  </van-sticky>

  <van-tabs active="{{activeTab}}" bind:change="onTabChange" sticky="false">
    <van-tab title="{{i18n.shift_detail_tab_onboard}} ({{onboardCount}})">
      <view class="tab-panel">
        <view wx:if="{{onboardCount === 0}}" class="card">
          <van-empty description="{{i18n.shift_detail_no_onboard}}" />
        </view>

        <view wx:else class="card">
          <view wx:for="{{onboardGroups}}" wx:key="key" class="group-block">
            <view class="group-header">{{item.label}}（{{item.count}}）</view>
            <view class="list-wrap">
              <view wx:for="{{item.items}}" wx:for-item="passenger" wx:key="id" class="passenger-item list-item-container">
                <view class="passenger-left">
                  <view class="passenger-top">
                    <text class="passenger-name">{{passenger.name}}</text>
                    <text class="passenger-meta">{{passenger.flight_no}} | {{passenger.terminal || '--'}}</text>
                  </view>
                  <view class="passenger-sub">{{i18n.shift_detail_pickup_time}}{{passenger.pickup_time_text || '--'}}</view>
                  <view class="passenger-sub">{{i18n.shift_detail_luggage_label}}{{passenger.checked_luggage_count || 0}}{{i18n.shift_detail_luggage_checked}} {{passenger.carryon_luggage_count || 0}}{{i18n.shift_detail_luggage_carry_on}}</view>
                  <view wx:if="{{passenger.ride_with_note}}" class="passenger-sub">{{i18n.shift_detail_ride_with_note}}{{passenger.ride_with_note}}</view>
                  <view wx:if="{{passenger.ride_with_wechat}}" class="passenger-sub">{{i18n.shift_detail_wechat}}{{passenger.ride_with_wechat}}</view>
                </view>
                <view class="passenger-right">
                  <van-button
                    type="danger"
                    size="small"
                    round
                    plain
                    custom-class="action-btn {{passenger.boarded_at ? 'action-btn-disabled' : ''}}"
                    loading="{{actingRequestId === passenger.id}}"
                    data-id="{{passenger.id}}"
                    data-boarded="{{passenger.boarded_at}}"
                    bind:tap="onRemovePassenger"
                  >{{i18n.shift_detail_remove}}</van-button>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </van-tab>

    <van-tab title="{{i18n.shift_detail_tab_pending}}">
      <view class="tab-panel">
        <van-dropdown-menu>
          <van-dropdown-item value="{{terminalFilter}}" options="{{terminalOptions}}" bind:change="onTerminalChange" />
          <van-dropdown-item value="{{dayFilter}}" options="{{dayOptions}}" bind:change="onDayChange" />
        </van-dropdown-menu>

        <view class="card pending-card">
          <view wx:if="{{pendingView.length === 0}}">
            <van-empty description="{{i18n.shift_detail_no_pending}}" />
          </view>

          <view wx:for="{{pendingGroups}}" wx:key="key" class="group-block">
            <view class="group-header">{{item.label}}（{{item.count}}）</view>
            <view class="list-wrap">
              <view wx:for="{{item.items}}" wx:for-item="passenger" wx:key="id" class="passenger-item list-item-container">
                <view class="passenger-left">
                  <view class="passenger-top">
                    <text class="passenger-name">{{passenger.name}}</text>
                    <text class="passenger-meta">{{passenger.flight_no}} | {{passenger.terminal || '--'}}</text>
                  </view>
                  <view class="passenger-sub">{{i18n.shift_detail_pickup_time}}{{passenger.pickup_time_text || '--'}}</view>
                  <view class="passenger-sub">{{i18n.shift_detail_luggage_label}}{{passenger.checked_luggage_count || 0}}{{i18n.shift_detail_luggage_checked}} {{passenger.carryon_luggage_count || 0}}{{i18n.shift_detail_luggage_carry_on}}</view>
                  <view wx:if="{{passenger.ride_with_note}}" class="passenger-sub">{{i18n.shift_detail_ride_with_note}}{{passenger.ride_with_note}}</view>
                  <view wx:if="{{passenger.ride_with_wechat}}" class="passenger-sub">{{i18n.shift_detail_wechat}}{{passenger.ride_with_wechat}}</view>
                  <view class="pending-tip-row">
                    <van-tag wx:if="{{passenger.recommended}}" type="success" plain>{{i18n.shift_detail_recommended}}</van-tag>
                    <van-tag wx:if="{{passenger.late}}" type="danger" plain>{{i18n.shift_detail_late}}</van-tag>
                  </view>
                </view>
                <view class="passenger-right">
                  <van-button
                    type="primary"
                    size="small"
                    round
                    custom-class="action-btn"
                    disabled="{{passenger.late}}"
                    loading="{{actingRequestId === passenger.id}}"
                    data-id="{{passenger.id}}"
                    bind:tap="onAddPassenger"
                  >{{i18n.shift_detail_add}}</van-button>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </van-tab>
  </van-tabs>

  <view class="bottom-bar">
    <van-button
      type="warning"
      block
      disabled="{{!canPublish}}"
      loading="{{publishing}}"
      bind:tap="onPublishShift"
    >{{publishButtonText}}</van-button>
  </view>
</view>
