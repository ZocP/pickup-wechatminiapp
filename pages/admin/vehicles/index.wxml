<view class="page vehicles-page">
  <view class="header-bar">
    <van-button type="primary" size="small" custom-style="width:auto;" bindtap="goAdd">{{i18n.vehicles_add_btn}}</van-button>
  </view>

  <view wx:if="{{loading && vehicleList.length === 0}}" class="card">
    <van-skeleton title row="3" />
  </view>

  <van-empty wx:elif="{{!loading && vehicleList.length === 0}}" description="{{i18n.vehicles_empty}}" />

  <view wx:else class="vehicle-list">
    <van-swipe-cell
      wx:for="{{vehicleList}}"
      wx:key="id"
      right-width="{{ 65 }}"
    >
      <van-cell
        title="{{item.car_model}}"
        label="{{item.car_plate ? item.car_plate : ''}}{{item.car_color ? ' · ' + item.car_color : ''}}"
        value="{{i18n.vehicles_seats}}{{item.seats_capacity}} / {{i18n.vehicles_checked}}{{item.checked_luggage_capacity}} / {{i18n.vehicles_carryon}}{{item.carry_on_capacity}}"
        is-link
        data-id="{{item.id || item.ID}}"
        bindtap="goEdit"
      />
      <view slot="right" class="swipe-delete-btn" data-id="{{item.id || item.ID}}" bindtap="onDeleteVehicle">
        {{i18n.vehicles_delete_btn}}
      </view>
    </van-swipe-cell>
  </view>

  <van-dialog id="van-dialog" />
  <van-toast id="van-toast" />
</view>
