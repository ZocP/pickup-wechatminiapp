.mod-review-page {
  padding-bottom: 40rpx;
}

.loading-wrap {
  padding: 24rpx;
}

.empty-wrap {
  padding-top: 100rpx;
}

.list {
  padding: 24rpx;
}

.mod-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.student-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.card-body {
  margin-bottom: 16rpx;
}

.info-line {
  font-size: 26rpx;
  color: #646566;
  margin-top: 8rpx;
}

.info-line.reason {
  color: #323233;
  font-weight: 500;
}

.info-line.time {
  font-size: 24rpx;
  color: #969799;
}

.card-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 16rpx 0 0;
  border-top: 1rpx solid #ebedf0;
  width: 100%;
  box-sizing: border-box;
}

.card-actions van-button {
  flex: 1;
  min-width: 0;
}

.new-details {
  margin: 12rpx 0;
  padding: 16rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
}

.new-details-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 8rpx;
}

.new-detail-line {
  font-size: 24rpx;
  color: #646566;
  margin-top: 6rpx;
}
