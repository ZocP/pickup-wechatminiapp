<view class="page home-page">
  <view class="card welcome-card">
    <view class="title">{{i18n.home_welcome}}</view>
    <view class="meta">
      <text>{{i18n.home_current_user}}{{userInfo.name || (i18n.home_user_prefix + (userInfo.id || '--'))}}</text>
      <van-tag type="primary" plain custom-style="margin-left: 12rpx;">{{userInfo.role || 'student'}}</van-tag>
    </view>
  </view>

  <view wx:if="{{isStudent}}" class="card section">
    <view class="apply-entry">
      <view class="section-title">{{i18n.home_apply_pickup}}</view>
      <van-cell-group inset>
        <van-cell title="{{i18n.home_student_apply}}" is-link bind:click="goStudentRequest" />
      </van-cell-group>
    </view>
  </view>

  <!-- 车辆管理 section -->
  <view class="card section" wx:if="{{isManageRole}}">
    <view class="section-title">{{i18n.home_vehicle_section}}</view>
    <van-cell-group inset>
      <van-cell title="{{i18n.home_vehicle_manage}}" is-link bind:click="goVehicleManage" />
      <van-cell title="{{i18n.home_driver_manage}}" is-link bind:click="goDriverManage" />
    </van-cell-group>
  </view>

  <!-- 人员管理 section -->
  <view class="card section" wx:if="{{isManageRole}}">
    <view class="section-title">{{i18n.home_personnel_section}}</view>
    <van-cell-group inset>
      <van-cell title="{{i18n.home_token_manage}}" is-link bind:click="goTokenManage" />
      <van-cell wx:if="{{canManageStaff}}" title="{{i18n.home_staff_manage}}" is-link bind:click="goStaffManage" />
      <van-cell title="{{i18n.home_passenger_manage}}" is-link bind:click="goPassengerManage" />
      <van-cell title="{{i18n.home_mod_review}}" is-link bind:click="goModificationReview">
        <van-tag wx:if="{{pendingModCount > 0}}" type="danger" round slot="right-icon">{{pendingModCount}}</van-tag>
      </van-cell>
      <van-cell title="{{i18n.home_admin_dispatch}}" is-link bind:click="goDispatch" />
    </van-cell-group>
  </view>

  <!-- 班次管理 section -->
  <view class="card section" wx:if="{{isManageRole}}">
    <view class="section-title">{{i18n.home_shift_mgmt_section}}</view>
    <van-cell-group inset>
      <van-cell title="{{i18n.home_roster_manage}}" is-link bind:click="goRosterManage" />
      <van-cell title="{{i18n.home_shift_center}}" is-link bind:click="goShiftCenter" />
    </van-cell-group>
  </view>

  <view wx:if="{{isDriver}}" class="card section">
    <view class="section-title">{{i18n.home_driver_section}}</view>
    <van-cell-group inset>
      <van-cell title="{{i18n.home_driver_my_shifts}}" is-link bind:click="goDriverPage" />
    </van-cell-group>
  </view>

  <view wx:if="{{isStudent}}" class="card section" bindtap="goToMyRequest">
    <view class="section-title">{{i18n.home_my_pickup_info}}</view>
    <view wx:if="{{loadingMyInfo}}">
      <van-skeleton title row="2" />
    </view>
    <block wx:elif="{{latestRequest}}">
      <view class="summary-line">
        <text>{{i18n.home_request_status}}{{latestRequest.status_text || latestRequest.status || '--'}}</text>
      </view>
      <view class="summary-line">
        <text>{{i18n.home_my_shift_time}}{{myShiftTime}}</text>
      </view>
    </block>
    <view wx:else class="summary-empty">
      {{i18n.home_no_request}}
    </view>
  </view>
</view>
