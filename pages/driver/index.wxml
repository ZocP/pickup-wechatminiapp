<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <van-loading size="24px" vertical>{{i18n.driver_loading}}</van-loading>
  </view>

  <!-- 无班次提示 -->
  <view wx:if="{{!loading && !currentShift}}" class="empty-container">
    <van-empty description="{{i18n.driver_no_shift}}" />
    <view class="empty-tips">{{i18n.driver_contact_admin}}</view>
  </view>

  <!-- 班次信息 -->
  <view wx:if="{{currentShift}}" class="shift-container">
    <van-cell-group>
      <van-cell title="{{i18n.driver_current_shift}}" value="{{formatTime(currentShift.departure_time)}}" />
      <van-cell title="{{i18n.driver_driver_label}}" value="{{currentShift.driver_name || i18n.driver_unassigned}}" />
      <van-cell title="{{i18n.driver_capacity_label}}" value="{{currentShift.capacity}}{{i18n.driver_capacity_unit}}" />
      <van-cell title="{{i18n.driver_assigned_label}}" value="{{currentShift.assigned_count}}{{i18n.driver_assigned_unit}}" />
      <van-cell title="{{i18n.driver_status_label}}" value="{{currentShift.status === 'published' ? i18n.driver_status_published : i18n.driver_status_unpublished}}" />
    </van-cell-group>

    <!-- 扫码登车按钮 -->
    <view class="scan-button-container">
      <van-button 
        type="primary" 
        size="large" 
        bindtap="openScanModal"
        loading="{{scanning}}"
      >
        {{i18n.driver_scan_btn}}
      </van-button>
    </view>

    <!-- 乘客列表 -->
    <view class="passengers-section">
      <view class="section-title">{{i18n.driver_passengers_title}} ({{passengers.length}}/{{currentShift.capacity}})</view>
      <van-cell-group wx:if="{{passengers.length > 0}}">
        <van-cell 
          wx:for="{{passengers}}" 
          wx:key="id"
          title="{{item.name}}"
          value="{{item.status === 'boarded' ? i18n.driver_boarded : i18n.driver_waiting}}"
        >
          <view slot="label">
            <text>{{i18n.driver_student_id}}{{item.student_id}}</text>
            <text wx:if="{{item.ride_with_wechat}}" class="ride-with-wechat">同乘微信：{{item.ride_with_wechat}}</text>
          </view>
        </van-cell>
      </van-cell-group>
      <view wx:else class="empty-passengers">
        <van-empty description="{{i18n.driver_no_passengers}}" mode="list" />
      </view>
    </view>
  </view>

  <!-- 扫码模态框 -->
  <van-popup 
    show="{{showScanModal}}" 
    position="bottom" 
    round
    bind:close="closeScanModal"
  >
    <view class="scan-modal">
      <view class="modal-header">
        <text class="modal-title">{{i18n.driver_scan_title}}</text>
        <van-icon name="cross" size="18px" bindtap="closeScanModal" />
      </view>
      
      <view class="scan-content">
        <!-- 扫码结果展示 -->
        <view wx:if="{{scanResult}}" class="scan-result">
          <van-icon 
            wx:if="{{scanResult.success}}" 
            name="checked" 
            color="#07c160" 
            size="48px" 
          />
          <van-icon 
            wx:else 
            name="clear" 
            color="#ee0a24" 
            size="48px" 
          />
          <view class="result-message">{{scanResult.message}}</view>
          <view class="scan-continue-hint">继续扫下一位？</view>
          <view class="scan-result-actions">
            <van-button type="primary" size="small" bindtap="continueScan">继续扫码</van-button>
            <van-button type="default" size="small" bindtap="finishScan">完成</van-button>
          </view>
        </view>

        <!-- 扫码按钮 -->
        <view wx:else class="scan-instruction">
          <view class="instruction-text">
            {{i18n.driver_scan_instruction}}
          </view>
          <view class="scan-button" bindtap="startScan">
            <van-icon name="scan" size="48px" color="#1989fa" />
            <text class="scan-text">{{i18n.driver_scan_start}}</text>
          </view>
          <view class="scan-tips">
            {{i18n.driver_scan_tips}}
          </view>
        </view>
      </view>
    </view>
  </van-popup>
</view>
