<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <van-loading size="24px" vertical>{{i18n.driver_loading}}</van-loading>
  </view>

  <!-- 无班次提示 -->
  <view wx:if="{{!loading && shifts.length === 0}}" class="empty-container">
    <van-empty description="{{i18n.driver_no_shift}}" />
    <view class="empty-tips">{{i18n.driver_contact_admin}}</view>
  </view>

  <!-- 班次卡片列表 -->
  <view wx:if="{{shifts.length > 0}}" class="shift-container">
    <view class="shift-list">
      <view
        wx:for="{{shifts}}"
        wx:key="id"
        class="shift-card {{selectedShiftId === item.id ? 'shift-card--active' : ''}}"
        bindtap="selectShift"
        data-id="{{item.id}}"
      >
        <view class="shift-card__header">
          <text class="shift-card__time">{{item.departureTimeFmt}}</text>
          <text wx:if="{{item.isToday}}" class="shift-card__badge">今天</text>
        </view>
        <view class="shift-card__info">
          <text>{{item.boardedCount}}/{{item.capacity}} 人已上车</text>
          <text class="shift-card__status">{{item.statusLabel}}</text>
        </view>
      </view>
    </view>

    <!-- 选中班次的详情和操作 -->
    <view wx:if="{{selectedShift}}" class="shift-detail">
      <!-- 扫码登车按钮 -->
      <view class="scan-button-container">
        <van-button
          type="primary"
          size="large"
          bindtap="openScanModal"
          loading="{{scanning}}"
        >
          {{i18n.driver_scan_btn}}
        </van-button>
      </view>

      <!-- 乘客列表 -->
      <view class="passengers-section">
        <view class="section-title">{{i18n.driver_passengers_title}} ({{passengers.length}}/{{selectedShift.capacity}})</view>
        <van-cell-group wx:if="{{passengers.length > 0}}">
          <van-cell
            wx:for="{{passengers}}"
            wx:key="id"
            title="{{item.name}}"
            value="{{item.status === 'boarded' ? i18n.driver_boarded : i18n.driver_waiting}}"
          >
            <view slot="label">
              <text>{{i18n.driver_student_id}}{{item.student_id}}</text>
              <text wx:if="{{item.ride_with_wechat}}" class="ride-with-wechat">{{i18n.driver_ride_with_wechat}}{{item.ride_with_wechat}}</text>
            </view>
          </van-cell>
        </van-cell-group>
        <view wx:else class="empty-passengers">
          <van-empty description="{{i18n.driver_no_passengers}}" mode="list" />
        </view>
      </view>
    </view>
  </view>

  <!-- 扫码模态框 -->
  <van-popup
    show="{{showScanModal}}"
    position="bottom"
    round
    bind:close="closeScanModal"
  >
    <view class="scan-modal">
      <view class="modal-header">
        <text class="modal-title">{{i18n.driver_scan_title}}</text>
        <van-icon name="cross" size="18px" bindtap="closeScanModal" />
      </view>

      <view class="scan-content">
        <!-- 扫码结果展示 -->
        <view wx:if="{{scanResult}}" class="scan-result">
          <van-icon
            wx:if="{{scanResult.success}}"
            name="checked"
            color="#07c160"
            size="48px"
          />
          <van-icon
            wx:else
            name="clear"
            color="#ee0a24"
            size="48px"
          />
          <view class="result-message">{{scanResult.message}}</view>
          <view class="scan-continue-hint">{{i18n.driver_scan_continue_hint}}</view>
          <view class="scan-result-actions">
            <van-button type="primary" size="small" bindtap="continueScan">{{i18n.driver_scan_continue_btn}}</van-button>
            <van-button type="default" size="small" bindtap="finishScan">{{i18n.driver_scan_finish_btn}}</van-button>
          </view>
        </view>

        <!-- 扫码按钮 -->
        <view wx:else class="scan-instruction">
          <view class="instruction-text">
            {{i18n.driver_scan_instruction}}
          </view>
          <view class="scan-button" bindtap="startScan">
            <van-icon name="scan" size="48px" color="#1989fa" />
            <text class="scan-text">{{i18n.driver_scan_start}}</text>
          </view>
          <view class="scan-tips">
            {{i18n.driver_scan_tips}}
          </view>
        </view>
      </view>
    </view>
  </van-popup>
</view>
