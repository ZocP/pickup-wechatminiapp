<view class="page bind-page">
  <view class="card bind-card">
    <view class="title">先完成微信号绑定</view>
    <view class="subtitle">未绑定前不可提交申请或使用任何业务功能</view>

    <van-notice-bar left-icon="warning-o" text="请务必填写正确微信号，填写错误将影响接机联系服务" />

    <van-field
      label="真实姓名"
      placeholder="请输入真实姓名"
      value="{{name}}"
      maxlength="64"
      bind:change="onNameChange"
      custom-style="margin-top: 20rpx;"
    />

    <van-field
      label="微信号"
      placeholder="请输入你的微信号"
      value="{{wechatID}}"
      maxlength="20"
      bind:change="onWechatIDChange"
      custom-style="margin-top: 12rpx;"
    />

    <van-button
      type="primary"
      block
      loading="{{loading}}"
      custom-style="margin-top: 24rpx;"
      bind:tap="onBindWechatID"
    >确认绑定微信号</van-button>

    <van-button
      type="default"
      plain
      block
      custom-style="margin-top: 16rpx;"
      bind:tap="logout"
    >退出登录</van-button>
  </view>
</view>
