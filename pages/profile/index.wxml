<view class="page profile-page">
  <view class="card">
    <view class="name">{{userInfo.name || ('用户#' + (userInfo.id || '--'))}}</view>
    <view class="meta">
      <text>角色</text>
      <van-tag type="primary" plain custom-style="margin-left: 12rpx;">{{userInfo.role || 'student'}}</van-tag>
    </view>
    <view class="meta" wx:if="{{isAdminReal}}">
      <text>当前视角</text>
      <van-tag type="warning" plain custom-style="margin-left: 12rpx;">
        {{currentEffectiveRole === 'admin' ? '管理员' : (currentEffectiveRole === 'staff' ? '工作人员' : (currentEffectiveRole === 'driver' ? '司机' : '乘客'))}}
      </van-tag>
    </view>
    <view class="meta">
      <text>微信号：{{userInfo.wechat_id || '--'}}</text>
    </view>
  </view>

  <view class="card section">
    <van-cell-group inset>
      <van-cell title="我的接机申请" is-link bind:click="goStudentRequest" />
    </van-cell-group>

    <van-button
      wx:if="{{isAdminReal}}"
      type="primary"
      plain
      block
      custom-style="margin-top: 18rpx;"
      bind:tap="openRolePicker"
    >切换视角</van-button>

    <van-button
      type="danger"
      plain
      block
      custom-style="margin-top: 22rpx;"
      bind:tap="logout"
    >退出登录</van-button>
  </view>

  <van-action-sheet
    show="{{showRolePicker}}"
    title="选择切换成什么视角"
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="closeRolePicker"
  />
</view>
