<view class="page profile-page">
  <view class="lang-switch-header">
    <view class="lang-switch-btn" bind:tap="switchLang">{{langLabel}}</view>
  </view>
  <view class="card">
    <view class="name">{{userInfo.name || (i18n.profile_user_prefix + (userInfo.id || '--'))}}</view>
    <view class="meta">
      <text>{{i18n.profile_role_label}}</text>
      <van-tag type="primary" plain custom-style="margin-left: 12rpx;">{{userInfo.role || 'student'}}</van-tag>
    </view>
    <view class="meta" wx:if="{{isAdminReal}}">
      <text>{{i18n.profile_current_view}}</text>
      <van-tag type="warning" plain custom-style="margin-left: 12rpx;">
        {{currentEffectiveRole === 'admin' ? i18n.profile_role_admin : (currentEffectiveRole === 'staff' ? i18n.profile_role_staff : (currentEffectiveRole === 'driver' ? i18n.profile_role_driver : i18n.profile_role_student))}}
      </van-tag>
    </view>
    <view class="meta">
      <text>{{i18n.profile_wechat_label}}{{userInfo.wechat_id || '--'}}</text>
    </view>
  </view>

  <view class="card section">
    <van-cell-group inset>
      <van-cell title="{{i18n.profile_my_request}}" is-link bind:click="goStudentRequest" />
    </van-cell-group>

    <van-button
      wx:if="{{isAdminReal}}"
      type="primary"
      plain
      block
      custom-style="margin-top: 18rpx;"
      bind:tap="openRolePicker"
    >{{i18n.profile_switch_view}}</van-button>

    <van-button
      type="danger"
      plain
      block
      custom-style="margin-top: 22rpx;"
      bind:tap="logout"
    >{{i18n.profile_logout}}</van-button>
  </view>

  <van-action-sheet
    show="{{showRolePicker}}"
    title="{{i18n.profile_role_picker_title}}"
    actions="{{roleOptions}}"
    close-on-click-action="true"
    bind:select="onSelectRole"
    bind:close="closeRolePicker"
  />
</view>
