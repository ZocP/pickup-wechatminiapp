.tokens-page {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.top-bar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.empty-wrap {
  margin-top: 80rpx;
}

.token-card {
  margin-bottom: 20rpx;
}

.token-code-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.token-code {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: #323233;
}

.token-meta {
  font-size: 24rpx;
  color: #646566;
  margin-bottom: 8rpx;
}

.meta-sep {
  margin: 0 10rpx;
  color: #c8c9cc;
}

.token-used-by {
  font-size: 24rpx;
  color: #07c160;
  margin-bottom: 8rpx;
}

.token-time {
  font-size: 22rpx;
  color: #969799;
  margin-bottom: 8rpx;
}

.token-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 8rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 24rpx;
}
