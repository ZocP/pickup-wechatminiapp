<view class="page login-page">
  <view class="card login-card">
    <view class="title">{{i18n.login_title}}</view>
    <view class="subtitle">{{i18n.login_subtitle}}</view>

    <van-notice-bar
      left-icon="info-o"
      text="{{i18n.login_notice}}"
    />

    <van-button
      type="primary"
      block
      loading="{{loading}}"
      custom-style="margin-top: 24rpx;"
      bind:tap="onLogin"
    >{{i18n.login_btn}}</van-button>
  </view>
</view>
